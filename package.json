{
    "name": "peekr",
    "version": "1.2.0",
    "type": "module",
    "description": "Browser-based ONNX eye tracking module using MediaPipe + onnxruntime-web",
    "scripts": {
        "build:face-worker": "vite build --config vite.face-worker.config.js",
        "predev": "npm run build:face-worker",
        "prebuild": "npm run build:face-worker",
        "dev": "vite",
        "build": "vite build",
        "build-gh": "vite build --base=./",
        "preview": "vite preview",
        "lint": "npx eslint --fix",
        "test": "vitest"
    },
    "keywords": [
        "eye-tracking",
        "onnx",
        "javascript",
        "webcam",
        "mediapipe",
        "onnxruntime-web"
    ],
    "author": "Aryaman Taore",
    "license": "MIT",
    "dependencies": {
        "@mediapipe/tasks-vision": "^0.10.35",
        "kalmanjs": "^1.1.0",
        "ndarray": "^1.0.19",
        "ndarray-ops": "^1.2.2",
        "onnxruntime-web": "^1.25.1"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@stylistic/eslint-plugin": "^5.2.0",
        "eslint": "^10.3.0",
        "globals": "^17.6.0",
        "vite": "^8.0.10",
        "vite-plugin-static-copy": "^4.1.0",
        "vite-plugin-wasm": "^3.5.0",
        "vitest": "^4.1.5"
    }
}
